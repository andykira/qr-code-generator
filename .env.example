# Django Configuration

# Security
# To get your local IP, run: ipconfig getifaddr en0 (macOS) or ip addr (Linux) or ipconfig (Windows)
# Replace YOUR_LOCAL_IP with your actual IP address
SECRET_KEY=django-insecure-0k*p9i620z0j!3-#wrw!e30tl)ab@3e231n3d6j91akfkxz(ej
DEBUG=True

# ALLOWED_HOSTS: localhost, 127.0.0.1, 0.0.0.0, and your local network IP
# Format: localhost,127.0.0.1,0.0.0.0,YOUR_LOCAL_IP (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# CORS allowed origins for local development
# For localhost: http://localhost:5173,http://127.0.0.1:5173
# For LAN access: add http://YOUR_LOCAL_IP:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# CSRF trusted origins
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
